msgstr "生成開始"

msgid "This generation is free"
msgstr "この生成は無料です"

msgid "Remaining points"
msgstr "残りポイント"

msgid "Image Upload Tips"
msgstr "画像アップロードのヒント"

msgid "It supports PNG, JPG, JPEG. Images should be no larger than 6MB with a minimum resolution of 128*128."
msgstr "PNG、JPG、JPEGに対応しています。画像サイズは6MB以下、解像度は128*128以上である必要があります。"

msgid "Simple background (preferably solid color)"
msgstr "シンプルな背景（できれば単色）"

msgid "No text included"
msgstr "テキストなし"

msgid "Single model"
msgstr "単一モデル"

msgid "The model should not be too small."
msgstr "モデルはあまり小さくないこと"

msgid "We're currently experiencing high demand. Please wait..."
msgstr "現在、多くのご利用が集中しています。お待ちください…"

msgid "Current queue"
msgstr "現在の待ち行列"

msgid "Maximum image resolution: 5000*5000"
msgstr "最大画像解像度：5000*5000"

