msgid "Error"
msgstr "エラー"

msgctxt "GuideWeb"
msgid "Loading..."
msgstr "読み込み中…"

msgid "Loading failed. Please try again."
msgstr "読み込みに失敗しました。もう一度お試しください。"

msgctxt "Flashforge"
msgid "Refer & Earn"
msgstr "紹介して獲得"

msgid "Copy Referral Link"
msgstr "紹介リンクをコピー"

msgid "Insufficient points"
msgstr "ポイント不足"

msgid "Generating, please wait..."
msgstr "生成中です。お待ちください…"

msgid "Generation successful!"
msgstr "生成成功！"

msgid "You can specify the number of colors for the model."
msgstr "モデルの色数を指定できます。"

